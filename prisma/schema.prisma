// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

// datasource db {
//   provider = "postgresql"
// }

datasource db {
  provider = "sqlite"
}

enum AccountType {
  ADMIN
  CLUB
}

model User {
  id        String   @id @default(cuid())
  username  String   @unique
  passwordHash  String
  type      AccountType @default(CLUB)

  clubId    String?
  club      Club?    @relation("ClubMembers", fields: [clubId], references: [id])

  sessions  Session[] @relation("SessionUser")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Club {
  id            String   @id @default(cuid()) 
  name          String   @unique
  members       User[]   @relation("ClubMembers")
  pictureUrl    String?

  description   String?

  notifications Notification[] @relation("clubNotifications")
  posts         Post[] @relation("clubPosts")
  
  instagramLink String?
  facebookLink  String?
  calenderLink  String?

  rssFeedLink   String?
  contactMail   String?
  contactPerson String?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Notification {
  id        String   @id @default(cuid())
  clubId    String
  club      Club     @relation("clubNotifications", fields: [clubId], references: [id])

  @@index([clubId])

  message   String
  sendNotification Boolean @default(true)

  expiresAt DateTime
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}

model Post {
  id        String   @id @default(cuid())
  clubId    String
  club      Club     @relation("clubPosts", fields: [clubId], references: [id])

  @@index([clubId])

  description  String

  picture    Picture[] @relation("postPictures")

  formLink    String?
  formLinkTitle   String?
  otherLinkTitle String?
  otherLink   String?

  sendNotification Boolean @default(true)
  preview Boolean @default(true)

  like       Like[]   @relation("LikePost")
  view       View[]   @relation("ViewPost")

  uploadedAt DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Picture {
  id        String   @id @default(cuid())

  postId    String
  post      Post     @relation("postPictures", fields: [postId], references: [id])

  pictureUrl       String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Session {
  id        String   @id @default(cuid())

  userId    String?
  user      User?     @relation("SessionUser", fields: [userId], references: [id])
  
  like Like[]   @relation("LikeSession")
  view View[]   @relation("ViewSession")

  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Like {
  id        String   @id @default(cuid())

  postId    String
  post      Post     @relation("LikePost", fields: [postId], references: [id])

  sessionId String
  session   Session  @relation("LikeSession", fields: [sessionId], references: [id])

  createdAt DateTime @default(now())

  @@index([postId])
  @@index([sessionId])
  
  @@unique([postId, sessionId])
}

model View {
  id        String   @id @default(cuid())

  postId    String
  post      Post     @relation("ViewPost", fields: [postId], references: [id])

  sessionId String
  session   Session  @relation("ViewSession", fields: [sessionId], references: [id])

  createdAt DateTime @default(now())

  @@index([postId])
  @@index([sessionId])

  @@unique([postId, sessionId])
}

